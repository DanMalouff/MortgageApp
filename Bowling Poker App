import React, { useState, useEffect, useRef, useCallback } from "react";

/* ============================================================
   BOWLING POKER — multiplayer 5-card draw for league night
   Each bowler joins from their own phone with a game code.
   Strike = card + "Great job" | Spare = card + "So average"
   Open = no card + "You suck" | Finish = fireworks for winner
   ============================================================ */

const SUITS = [
  { s: 0, sym: "♠", color: "#1b1f2a" },
  { s: 1, sym: "♥", color: "#c8323e" },
  { s: 2, sym: "♦", color: "#c8323e" },
  { s: 3, sym: "♣", color: "#1b1f2a" },
];
const RANKS = [14, 13, 12, 11, 10, 9, 8, 7, 6, 5, 4, 3, 2];
const RNAME = { 14: "A", 13: "K", 12: "Q", 11: "J", 10: "10", 9: "9", 8: "8", 7: "7", 6: "6", 5: "5", 4: "4", 3: "3", 2: "2" };

const key = (c) => c.r + "-" + c.s;
const uid = () => Math.random().toString(36).slice(2, 10);
const makeCode = () => {
  const A = "ABCDEFGHJKMNPQRSTUVWXYZ23456789";
  let s = "";
  for (let i = 0; i < 4; i++) s += A[Math.floor(Math.random() * A.length)];
  return s;
};

function fullDeck(decks) {
  const out = [];
  for (let d = 0; d < decks; d++)
    for (const su of SUITS) for (const r of RANKS) out.push({ r, s: su.s });
  return out;
}

/* ---------------- audio ---------------- */
let _ctx = null;
function ac() {
  try {
    _ctx = _ctx || new (window.AudioContext || window.webkitAudioContext)();
    if (_ctx.state === "suspended") _ctx.resume();
    return _ctx;
  } catch (e) {
    return null;
  }
}
function say(text) {
  try {
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.rate = 0.95;
    u.pitch = 1;
    window.speechSynthesis.speak(u);
  } catch (e) {}
}
function crowdCheer() {
  const c = ac();
  if (!c) return;
  const dur = 7;
  // swelling crowd roar
  const buf = c.createBuffer(1, c.sampleRate * dur, c.sampleRate);
  const d = buf.getChannelData(0);
  for (let i = 0; i < d.length; i++) {
    const env = Math.pow(Math.sin((Math.PI * i) / d.length), 0.6);
    d[i] = (Math.random() * 2 - 1) * env;
  }
  const src = c.createBufferSource();
  src.buffer = buf;
  const f = c.createBiquadFilter();
  f.type = "bandpass";
  f.frequency.value = 900;
  f.Q.value = 0.4;
  const g = c.createGain();
  g.gain.setValueAtTime(0.0001, c.currentTime);
  g.gain.exponentialRampToValueAtTime(0.55, c.currentTime + 0.7);
  g.gain.exponentialRampToValueAtTime(0.001, c.currentTime + dur);
  src.connect(f);
  f.connect(g);
  g.connect(c.destination);
  src.start();
  // scattered claps and whistles
  for (let i = 0; i < 90; i++) {
    const t = c.currentTime + Math.random() * dur * 0.85;
    const b = c.createBuffer(1, Math.floor(c.sampleRate * 0.05), c.sampleRate);
    const dd = b.getChannelData(0);
    for (let j = 0; j < dd.length; j++) dd[j] = (Math.random() * 2 - 1) * Math.exp((-j / dd.length) * 9);
    const s2 = c.createBufferSource();
    s2.buffer = b;
    const hp = c.createBiquadFilter();
    hp.type = "highpass";
    hp.frequency.value = 1400;
    const gg = c.createGain();
    gg.gain.value = 0.18 + Math.random() * 0.14;
    s2.connect(hp);
    hp.connect(gg);
    gg.connect(c.destination);
    s2.start(t);
  }
  for (let i = 0; i < 6; i++) {
    const t = c.currentTime + 0.5 + Math.random() * 4.5;
    const o = c.createOscillator();
    o.type = "sine";
    o.frequency.setValueAtTime(1800 + Math.random() * 600, t);
    o.frequency.exponentialRampToValueAtTime(2600 + Math.random() * 500, t + 0.25);
    const gw = c.createGain();
    gw.gain.setValueAtTime(0.0001, t);
    gw.gain.exponentialRampToValueAtTime(0.06, t + 0.05);
    gw.gain.exponentialRampToValueAtTime(0.0001, t + 0.35);
    o.connect(gw);
    gw.connect(c.destination);
    o.start(t);
    o.stop(t + 0.4);
  }
}
function fireworkPop() {
  const c = ac();
  if (!c) return;
  const t = c.currentTime;
  const b = c.createBuffer(1, Math.floor(c.sampleRate * 0.3), c.sampleRate);
  const dd = b.getChannelData(0);
  for (let j = 0; j < dd.length; j++) dd[j] = (Math.random() * 2 - 1) * Math.exp((-j / dd.length) * 6);
  const s = c.createBufferSource();
  s.buffer = b;
  const lp = c.createBiquadFilter();
  lp.type = "lowpass";
  lp.frequency.value = 500 + Math.random() * 900;
  const g = c.createGain();
  g.gain.value = 0.35;
  s.connect(lp);
  lp.connect(g);
  g.connect(c.destination);
  s.start(t);
}

/* ---------------- hand evaluation ---------------- */
const cmpScore = (a, b) => {
  const n = Math.max(a.length, b.length);
  for (let i = 0; i < n; i++) {
    const x = a[i] || 0, y = b[i] || 0;
    if (x !== y) return x - y;
  }
  return 0;
};

function evalCombo(cards, wildSet, rule) {
  const n = cards.length;
  const naturals = cards.filter((c) => !wildSet.has(key(c)));
  const w = n - naturals.length;
  const cnt = {};
  naturals.forEach((c) => (cnt[c.r] = (cnt[c.r] || 0) + 1));
  const entries = Object.keys(cnt)
    .map((r) => [+r, cnt[r]])
    .sort((a, b) => b[1] - a[1] || b[0] - a[0]);
  const distinct = entries.length;
  const natRanks = naturals.map((c) => c.r);
  const suitSet = new Set(naturals.map((c) => c.s));
  const flushOK = n === 5 && suitSet.size <= 1;

  let straightHigh = 0;
  if (n === 5 && distinct === naturals.length) {
    for (let high = 14; high >= 5; high--) {
      const win = new Set();
      for (let k2 = 0; k2 < 5; k2++) {
        let r = high - k2;
        if (r === 1) r = 14;
        win.add(r);
      }
      if (natRanks.every((r) => win.has(r))) {
        straightHigh = high;
        break;
      }
    }
  }
  const royal = flushOK && straightHigh === 14;
  const fiveOK = n === 5 && distinct <= 1;
  const fiveRank = fiveOK ? (distinct === 1 ? entries[0][0] : 14) : 0;

  const restKickers = (exclRank, used) => {
    const rest = natRanks.filter((r) => r !== exclRank).sort((a, b) => b - a);
    return rest;
  };

  // rule-dependent top tier
  if (rule === "naturalRoyal") {
    if (royal && w === 0) return { s: [12], name: "Natural Royal Flush" };
    if (fiveOK) return { s: [11, fiveRank], name: "Five of a Kind — " + RNAME[fiveRank] + "s" };
    if (royal) return { s: [10], name: "Royal Flush (wild)" };
  } else {
    if (fiveOK) return { s: [11, fiveRank], name: "Five of a Kind — " + RNAME[fiveRank] + "s" };
    if (royal) return { s: [10], name: "Royal Flush" };
  }
  if (flushOK && straightHigh > 0)
    return { s: [9, straightHigh], name: "Straight Flush, " + RNAME[straightHigh] + " high" };

  // quads
  if (n >= 4) {
    for (const r of RANKS) {
      const c = Math.min(cnt[r] || 0, 4);
      if (c + w >= 4 && (c > 0 || w >= 4)) {
        const used = Math.max(0, 4 - c);
        const leftoverW = w - used;
        const rest = natRanks.filter((x) => x !== r).sort((a, b) => b - a);
        const kick = leftoverW > 0 ? 14 : rest[0] || 0;
        return { s: [8, r, kick], name: "Four of a Kind — " + RNAME[r] + "s" };
      }
    }
  }
  // full house
  if (n === 5 && distinct >= 2) {
    let best = null;
    for (const [a, ca] of entries)
      for (const [b, cb] of entries) {
        if (a === b) continue;
        const need = Math.max(0, 3 - ca) + Math.max(0, 2 - cb);
        if (need <= w) {
          const sc = [7, a, b];
          if (!best || cmpScore(sc, best.s) > 0) best = { s: sc, name: "Full House — " + RNAME[a] + "s over " + RNAME[b] + "s" };
        }
      }
    if (best) return best;
  }
  if (flushOK) {
    const tb = [...natRanks, ...Array(w).fill(14)].sort((a, b) => b - a);
    return { s: [6, ...tb], name: "Flush, " + RNAME[tb[0]] + " high" };
  }
  if (straightHigh > 0) return { s: [5, straightHigh], name: "Straight, " + RNAME[straightHigh] + " high" };
  // trips
  if (n >= 3) {
    for (const r of RANKS) {
      const c = cnt[r] || 0;
      if (c + w >= 3 && (c > 0 || w >= 3)) {
        const rest = natRanks.filter((x) => x !== r).sort((a, b) => b - a);
        return { s: [4, r, ...rest.slice(0, 2)], name: "Three of a Kind — " + RNAME[r] + "s" };
      }
    }
  }
  // two pair (naturals only; a wild would have made trips)
  if (distinct >= 2 && entries[0][1] >= 2 && entries[1][1] >= 2) {
    const rest = natRanks.filter((x) => x !== entries[0][0] && x !== entries[1][0]).sort((a, b) => b - a);
    return {
      s: [3, entries[0][0], entries[1][0], rest[0] || 0],
      name: "Two Pair — " + RNAME[entries[0][0]] + "s & " + RNAME[entries[1][0]] + "s",
    };
  }
  // pair
  if (n >= 2) {
    for (const r of RANKS) {
      const c = cnt[r] || 0;
      if (c + w >= 2 && (c > 0 || w >= 2)) {
        const rest = natRanks.filter((x) => x !== r).sort((a, b) => b - a);
        return { s: [2, r, ...rest.slice(0, 3)], name: "Pair of " + RNAME[r] + "s" };
      }
    }
  }
  const tb = natRanks.sort((a, b) => b - a);
  return { s: [1, ...tb], name: tb.length ? RNAME[tb[0]] + " high" : "No cards" };
}

function* combos(arr, k) {
  const n = arr.length;
  if (k > n) return;
  const idx = Array.from({ length: k }, (_, i) => i);
  while (true) {
    yield idx.map((i) => arr[i]);
    let i = k - 1;
    while (i >= 0 && idx[i] === n - k + i) i--;
    if (i < 0) return;
    idx[i]++;
    for (let j = i + 1; j < k; j++) idx[j] = idx[j - 1] + 1;
  }
}

function bestHand(cards, wildSet, rule) {
  if (!cards.length) return { s: [0], name: "No cards", five: [] };
  const k = Math.min(5, cards.length);
  let best = null;
  for (const c5 of combos(cards, k)) {
    const r = evalCombo(c5, wildSet, rule);
    if (!best || cmpScore(r.s, best.s) > 0) best = { ...r, five: c5 };
  }
  return best;
}

/* ---------------- storage ---------------- */
async function sGet(k) {
  try {
    const r = await window.storage.get(k, true);
    return r ? JSON.parse(r.value) : null;
  } catch (e) {
    return null;
  }
}
async function sSet(k, v) {
  try {
    await window.storage.set(k, JSON.stringify(v), true);
    return true;
  } catch (e) {
    return false;
  }
}
const metaKey = (code) => "bpkr:" + code + ":meta";
const playerKey = (code, id) => "bpkr:" + code + ":p:" + id;

/* ---------------- fireworks ---------------- */
function Fireworks() {
  const ref = useRef(null);
  useEffect(() => {
    const cv = ref.current;
    const ctx = cv.getContext("2d");
    let W = (cv.width = window.innerWidth);
    let H = (cv.height = window.innerHeight);
    let parts = [];
    let alive = true;
    const colors = ["#ffd447", "#ff5c8a", "#5cc8ff", "#7dffa0", "#ffffff", "#ff9d47"];
    function burst() {
      const x = W * (0.15 + Math.random() * 0.7);
      const y = H * (0.12 + Math.random() * 0.45);
      const col = colors[Math.floor(Math.random() * colors.length)];
      const N = 60 + Math.floor(Math.random() * 40);
      for (let i = 0; i < N; i++) {
        const a = (Math.PI * 2 * i) / N + Math.random() * 0.2;
        const v = 1.5 + Math.random() * 3.5;
        parts.push({ x, y, vx: Math.cos(a) * v, vy: Math.sin(a) * v, life: 60 + Math.random() * 30, col });
      }
      fireworkPop();
    }
    const iv = setInterval(() => alive && burst(), 700);
    burst();
    function tick() {
      if (!alive) return;
      ctx.fillStyle = "rgba(8,10,18,0.22)";
      ctx.fillRect(0, 0, W, H);
      parts = parts.filter((p) => p.life > 0);
      for (const p of parts) {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.04;
        p.vx *= 0.985;
        p.vy *= 0.985;
        p.life--;
        ctx.globalAlpha = Math.max(0, p.life / 70);
        ctx.fillStyle = p.col;
        ctx.fillRect(p.x, p.y, 2.6, 2.6);
      }
      ctx.globalAlpha = 1;
      requestAnimationFrame(tick);
    }
    tick();
    const onR = () => {
      W = cv.width = window.innerWidth;
      H = cv.height = window.innerHeight;
    };
    window.addEventListener("resize", onR);
    const stop = setTimeout(() => {
      alive = false;
      clearInterval(iv);
    }, 14000);
    return () => {
      alive = false;
      clearInterval(iv);
      clearTimeout(stop);
      window.removeEventListener("resize", onR);
    };
  }, []);
  return (
    <canvas
      ref={ref}
      style={{ position: "fixed", inset: 0, zIndex: 40, pointerEvents: "none" }}
    />
  );
}

/* ---------------- card ---------------- */
function PCard({ c, wild, small, onClick, selected }) {
  const su = SUITS[c.s];
  return (
    <div
      onClick={onClick}
      style={{
        width: small ? 44 : 58,
        height: small ? 62 : 82,
        borderRadius: 8,
        background: "#fdfaf2",
        border: wild ? "2px solid #ffd447" : "1px solid #b9b2a4",
        boxShadow: selected ? "0 0 0 3px #ff5c8a" : "0 2px 4px rgba(0,0,0,0.35)",
        display: "flex",
        flexDirection: "column",
        alignItems: "center",
        justifyContent: "center",
        color: su.color,
        fontWeight: 800,
        fontSize: small ? 15 : 19,
        lineHeight: 1.05,
        cursor: onClick ? "pointer" : "default",
        position: "relative",
        userSelect: "none",
        flexShrink: 0,
      }}
    >
      <div>{RNAME[c.r]}</div>
      <div style={{ fontSize: small ? 17 : 22 }}>{su.sym}</div>
      {wild && (
        <div style={{ position: "absolute", top: 1, right: 3, fontSize: 10, color: "#b8860b" }}>★</div>
      )}
    </div>
  );
}

/* ---------------- big alley button ---------------- */
function AlleyBtn({ label, sub, color, onClick, disabled }) {
